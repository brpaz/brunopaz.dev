{
  "name": "@brpaz/brunopazdev",
  "description": "Personal website for Bruno Paz",
  "author": {
    "name": "Bruno Paz",
    "email": "info@brunopaz.dev",
    "url": "https://brunopaz.dev"
  },
  "version": "1.10.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "preview": "astro preview",
    "build": "astro build",
    "format:check": "prettier --check src/**/*.{astro,ts,js}",
    "format": "prettier --write src/**/*.{astro,ts,js}",
    "lint": "npm-run-all lint:*",
    "lint:js": "eslint src",
    "lint:js:fix": "eslint src --fix",
    "lint:astro": "astro check",
    "lint:md": "markdownlint src/content/**/*.mdx",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report",
    "test:lh": "lhci collect",
    "test:lh:report": "lhci open",
    "icons:optimize": "svgo -r --config=svgo.config.js --input=src/assets/icons"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.59.1",
    "@sarissa/pagination": "^1.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.61.1",
    "astro": "^6.4.8",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-playwright": "^2.10.4",
    "js-yaml": "^4.2.0",
    "lighthouse-cli": "^0.1.2",
    "markdown-it": "^14.2.0",
    "markdownlint-cli": "^0.49.0",
    "node-fetch": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@resvg/resvg-js": "^2.6.2",
    "@splidejs/splide": "^4.1.4",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro-favicons": "^3.1.6",
    "astro-loading-indicator": "^0.8.0",
    "canvaskit-wasm": "^0.41.1",
    "satori": "^0.26.0",
    "slugify": "^1.6.9"
  }
