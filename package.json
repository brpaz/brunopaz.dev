{
  "name": "brunopazdev",
  "private": true,
  "scripts": {
    "build": "gridsome build",
    "develop": "gridsome develop",
    "explore": "gridsome explore",
    "lint": "eslint src --ext .js,.vue",
    "lint:fix": "eslint src --ext .js,.vue --fix"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^1.3.0",
    "@gridsome/plugin-sitemap": "^0.2.2",
    "@gridsome/source-filesystem": "^0.6.1",
    "@gridsome/transformer-remark": "^0.3.4",
    "@gridsome/vue-remark": "^0.1.6",
    "axios": "^0.19.0",
    "gridsome": "^0.7.7",
    "gridsome-plugin-modal": "^0.1.1",
    "gridsome-plugin-remark-shiki": "^0.3.0",
    "gridsome-plugin-rss": "^1.2.0",
    "vue-scrollto": "^2.17.1"
  },
  "devDependencies": {
    "commitizen": "^4.0.3",
    "cypress": "^3.7.0",
    "cz-conventional-changelog": "3.0.2",
    "eslint": "^6.7.2",
    "eslint-config-prettier": "^6.7.0",
    "eslint-plugin-gridsome": "^1.4.0",
    "husky": "^3.1.0",
    "lint-staged": "^9.5.0",
    "prettier": "^1.19.1",
    "stylelint": "^12.0.0",
    "stylelint-config-recommended": "^3.0.0",
    "tailwindcss": "^1.1.4",
    "vue-eslint-parser": "^7.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "prepare-commit-msg": "exec < /dev/tty && git cz --hook || true"
    }
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint src --ext .js,.vue --fix",
      "git add"
    ]
  }
}
