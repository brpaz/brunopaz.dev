{
  "name": "brunopazdev",
  "private": true,
  "scripts": {
    "build": "gridsome build",
    "dev": "gridsome develop",
    "explore": "gridsome explore",
    "lint": "eslint src --ext .js,.vue",
    "lint:fix": "eslint src --ext .js,.vue --fix",
    "cypress:open": "cypress open",
    "cy:run": "cypress run"
  },
  "dependencies": {
    "@fullhuman/postcss-purgecss": "^1.3.0",
    "@gridsome/plugin-google-analytics": "^0.1.0",
    "@gridsome/plugin-sitemap": "^0.2.3",
    "@gridsome/source-filesystem": "^0.6.2",
    "@gridsome/transformer-remark": "^0.4.0",
    "@gridsome/vue-remark": "^0.1.9",
    "axios": "^0.19.0",
    "gridsome": "^0.7.12",
    "gridsome-plugin-modal": "brpaz/gridsome-plugin-modal#add-modal-options",
    "gridsome-plugin-netlify-cms": "^1.0.9",
    "gridsome-plugin-remark-shiki": "^0.3.0",
    "gridsome-plugin-rss": "^1.2.0",
    "gridsome-plugin-sentry": "^1.0.0",
    "netlify-cms": "^2.10.2",
    "vue-disqus": "^3.0.5",
    "vue-scrollto": "^2.17.1",
    "tailwindcss": "^1.1.4"
  },
  "devDependencies": {
    "commitizen": "^4.0.3",
    "cypress": "^3.8.0",
    "cz-conventional-changelog": "3.0.2",
    "eslint": "^6.7.2",
    "eslint-config-prettier": "^6.7.0",
    "eslint-plugin-gridsome": "^1.4.0",
    "husky": "^3.1.0",
    "lint-staged": "^9.5.0",
    "prettier": "^1.19.1",
    "stylelint": "^12.0.0",
    "stylelint-config-recommended": "^3.0.0",
    "vue-eslint-parser": "^7.0.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "prepare-commit-msg": "exec < /dev/tty && git cz --hook || true"
    }
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint src --ext .js,.vue --fix",
      "git add"
    ]
  }
}
