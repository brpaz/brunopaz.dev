---
import siteData from '~/content/site';
const currentYear = new Date().getFullYear();
const { social } = siteData;

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/blog/page/1', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
  { href: '/support', label: 'Support' },
];
---

<footer class="bg-neutral-900 border-t border-neutral-800 w-full mt-auto">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <nav class="flex justify-center gap-8 mb-8">
      {
        navLinks.map(({ href, label }) => (
          <a href={href} class="text-sm text-neutral-400 hover:text-white transition-colors duration-200">
            {label}
          </a>
        ))
      }
    </nav>

    <div class="flex justify-center gap-5 mb-8">
      <a
        href={social.github}
        target="_blank"
        rel="noopener"
        title="GitHub"
        class="text-neutral-500 hover:text-neutral-300 transition-colors duration-200"
      >
        <span class="sr-only">GitHub</span>
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
          >
          </path>
        </svg>
      </a>

      <a
        href={social.linkedin}
        target="_blank"
        rel="noopener"
        title="LinkedIn"
        class="text-neutral-500 hover:text-neutral-300 transition-colors duration-200"
      >
        <span class="sr-only">LinkedIn</span>
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          >
          </path>
        </svg>
      </a>

      <a
        href={social.mastodon}
        target="_blank"
        rel="noopener"
        title="Mastodon"
        class="text-neutral-500 hover:text-neutral-300 transition-colors duration-200"
      >
        <span class="sr-only">Mastodon</span>
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 448 512" aria-hidden="true">
          <path
            d="M433 179.1c0-97.2-63.7-125.7-63.7-125.7-62.5-28.7-228.6-28.4-290.5 0 0 0-63.7 28.5-63.7 125.7 0 115.7-6.6 259.4 105.6 289.1 40.5 10.7 75.3 13 103.3 11.4 50.8-2.8 79.3-18.1 79.3-18.1l-1.7-36.9s-36.3 11.4-77.1 10.1c-40.4-1.4-83-4.4-89.6-54a102.5 102.5 0 0 1-.9-13.9c85.6 20.9 158.7 9.1 178.8 6.7 56.1-6.7 105-41.3 111.2-72.9 9.8-49.8 9-121.5 9-121.5zm-75.1 125.2h-46.6v-114.2c0-49.7-64-51.6-64 6.9v62.5h-46.3V197c0-58.5-64-56.6-64-6.9v114.2H90.2c0-122.1-5.2-147.9 18.4-175 25.9-28.9 79.8-30.8 103.8 6.1l11.6 19.5 11.6-19.5c24.1-37.1 78.1-34.8 103.8-6.1 23.7 27.3 18.4 53 18.4 175z"
          >
          </path>
        </svg>
      </a>

      <a
        href={social.nostr}
        target="_blank"
        rel="noopener"
        title="Nostr"
        class="text-neutral-500 hover:text-neutral-300 transition-colors duration-200"
      >
        <span class="sr-only">Nostr</span>
        <svg
          class="h-5 w-5"
          viewBox="0 0 620 620"
          fill="currentColor"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M620 270.227V597.655C620 609.968 610.081 619.961 597.859 619.961H332.161C319.938 619.961 310.02 609.968 310.02 597.655V536.678C311.23 461.931 319.079 390.332 335.558 357.759C345.438 338.168 361.722 327.506 380.427 321.802C415.768 311.102 477.779 318.419 504.099 317.16C504.099 317.16 583.605 320.346 583.605 274.987C583.605 238.48 548.07 241.352 548.07 241.352C508.902 242.374 479.068 239.699 459.738 232.028C427.365 219.203 426.272 195.678 426.155 187.81C424.554 96.934 291.549 86.0368 174.359 108.579C46.2354 133.127 175.765 318.143 175.765 565.121V598.088C175.531 610.204 165.807 620 153.702 620H22.1415C9.91874 620 0 610.008 0 597.694V31.3934C0 19.08 9.91874 9.08757 22.1415 9.08757H145.813C158.036 9.08757 167.955 19.08 167.955 31.3934C167.955 49.6866 188.378 59.8756 203.139 49.2145C247.617 17.113 304.709 0 368.595 0C511.714 0 619.922 84.0305 619.922 270.227H620ZM382.419 203.782C382.419 177.424 361.214 156.062 335.051 156.062C308.887 156.062 287.683 177.424 287.683 203.782C287.683 230.14 308.887 251.501 335.051 251.501C361.214 251.501 382.419 230.14 382.419 203.782Z"
          >
          </path>
        </svg>
      </a>

      <a
        href={social.devto}
        target="_blank"
        rel="noopener"
        title="Dev.to"
        class="text-neutral-500 hover:text-neutral-300 transition-colors duration-200"
      >
        <span class="sr-only">Dev.to</span>
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 448 512" aria-hidden="true">
          <path
            d="M120.12 208.29c-3.88-2.9-7.77-4.35-11.65-4.35H91.03v104.47h17.45c3.88 0 7.77-1.45 11.65-4.35 3.88-2.9 5.82-7.25 5.82-13.06v-69.65c-.01-5.8-1.96-10.16-5.83-13.06zM404.1 32H43.9C19.7 32 .06 51.59 0 75.8v360.4C.06 460.41 19.7 480 43.9 480h360.2c24.21 0 43.84-19.59 43.9-43.8V75.8c-.06-24.21-19.7-43.8-43.9-43.8zM154.2 291.19c0 18.81-11.61 47.31-48.36 47.25h-46.4V172.98h47.38c35.44 0 47.36 28.46 47.37 47.28l.01 70.93zm100.68-88.66H201.6v38.42h32.57v29.57H201.6v38.41h53.29v29.57h-62.18c-11.16.29-20.44-8.53-20.72-19.69V193.7c-.27-11.15 8.56-20.41 19.71-20.69h63.19l-.01 29.52zm103.64 115.29c-13.2 30.75-36.85 24.63-47.44 0l-38.53-144.8h32.57l29.71 113.72 29.57-113.72h32.58l-38.46 144.8z"
          >
          </path>
        </svg>
      </a>

      <a
        href="/blog/rss.xml"
        title="RSS Feed"
        class="text-neutral-500 hover:text-neutral-300 transition-colors duration-200"
      >
        <span class="sr-only">RSS Feed</span>
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 448 512" aria-hidden="true">
          <path
            d="M0 64C0 46.3 14.3 32 32 32C279.4 32 480 232.6 480 480c0 17.7-14.3 32-32 32s-32-14.3-32-32C416 268.3 243.7 96 32 96 14.3 96 0 81.7 0 64zM0 184c0-17.7 14.3-32 32-32 181.7 0 328 146.3 328 328 0 17.7-14.3 32-32 32s-32-14.3-32-32c0-146.4-117.6-264-264-264-17.7 0-32-14.3-32-32zm96 248a56 56 0 1 1-112 0 56 56 0 1 1 112 0z"
          >
          </path>
        </svg>
      </a>
    </div>

    <p class="text-center text-xs text-neutral-600">
      &copy; {currentYear} Bruno Paz. All rights reserved.
    </p>
  </div>
</footer>
