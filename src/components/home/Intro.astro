---
import { Image } from 'astro:assets';
import profileImage from '~/assets/images/profile_pic.jpg';
---

<section class="flex flex-col mx-auto py-12 md:py-20">
  <div class="max-w-4xl mx-auto w-full">
    <div class="flex flex-col items-center mb-12">
      <div class="relative mb-8">
        <Image
          src={profileImage}
          alt="Profile"
          aria-hidden="true"
          width="200"
          height="200"
          class="rounded-full border-4 border-white shadow-2xl"
          loading="eager"
        />
      </div>

      <div class="text-center space-y-3">
        <div>
          <h1 class="font-bold text-neutral-900 text-5xl md:text-6xl mb-3">Bruno Paz</h1>
          <p class="text-2xl md:text-3xl text-primary-500 font-semibold mb-4">Tech Lead / Software Engineer</p>
        </div>

        <p class="text-lg md:text-xl text-neutral-700 leading-relaxed max-w-2xl mx-auto">
          Building software that solves real problems.
        </p>

        <span class="text-sm text-neutral-500">Porto, Portugal 🇵🇹</span>

        <div class="pt-2">
          <a
            href="/cv"
            class="inline-flex items-center px-5 py-2 rounded-lg border border-neutral-300 text-sm font-medium text-neutral-700 hover:border-primary-400 hover:text-primary-600 transition-colors duration-200"
          >
            View CV ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
