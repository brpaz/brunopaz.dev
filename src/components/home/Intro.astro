---
import { Image } from 'astro:assets';
import profileImage from '~/assets/images/profile_pic.jpg';
---

<section class="h-card flex flex-col mx-auto py-12 md:py-20">
  <div class="max-w-4xl mx-auto w-full">
    <div class="flex flex-col items-center mb-12">
      <div class="relative mb-8">
        <Image
          src={profileImage}
          alt=""
          aria-hidden="true"
          width="200"
          height="200"
          class="u-photo rounded-full border-4 border-white shadow-2xl"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <div class="text-center space-y-3">
        <div>
          <h1 class="p-name font-bold text-neutral-900 text-5xl md:text-6xl mb-3">Bruno Paz</h1>
          <p class="p-job-title text-2xl md:text-3xl text-primary-500 font-semibold mb-4">
            Tech Lead / Software Engineer
          </p>
        </div>

        <p class="p-note text-lg md:text-xl text-neutral-700 leading-relaxed max-w-2xl mx-auto">
          Building software that solves real problems.
        </p>

        <span class="text-sm text-neutral-500">Porto, Portugal 🇵🇹</span>
        <data class="p-locality" value="Porto" hidden></data>
        <data class="p-country-name" value="Portugal" hidden></data>
        <a class="u-url u-uid" href="https://brunopaz.dev" hidden></a>
        <a class="u-email" href="mailto:bruno@brunopaz.dev" hidden></a>

        <div class="pt-2">
          <a
            href="/cv"
            class="inline-flex items-center px-5 py-2 rounded-lg border border-neutral-300 text-sm font-medium text-neutral-700 hover:border-primary-400 hover:text-primary-600 transition-colors duration-200"
          >
            View CV ↗
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
