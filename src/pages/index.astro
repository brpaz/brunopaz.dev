---
import DefaultLayout from '../layouts/Default.astro';
import Intro from '@components/home/Intro.astro';
import WhatIDo from '@components/home/WhatIDo.astro';
import RecentPosts from '@components/home/RecentPosts.astro';
import ContactCTA from '@components/home/ContactCTA.astro';
import site from '~/content/site';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Bruno Paz',
  url: 'https://brunopaz.dev',
  jobTitle: 'Tech Lead / Software Engineer',
  sameAs: [site.social.github, site.social.linkedin, site.social.mastodon, site.social.devto],
};
---

<DefaultLayout jsonLd={personSchema}>
  <Intro />
  <WhatIDo />
  <RecentPosts />
  <ContactCTA />
</DefaultLayout>
