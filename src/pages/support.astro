---
import { Image } from 'astro:assets';
import DefaultLayout from '../layouts/Default.astro';
import site from '~/content/site';
import BitcoinQR from '~/assets/images/bitcoin_qr.png';
---

<DefaultLayout title="Bruno Paz | Support">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-2xl font-bold text-neutral-900 mb-3">Support My Work</h1>
    <p class="text-base text-neutral-600 leading-relaxed mb-10">
      If you've found my open source projects, blog posts, or other work helpful, consider supporting my efforts. Your
      contribution helps me dedicate more time to creating and sharing content with the community.
    </p>

    <div class="flex flex-col gap-4 max-w-md mb-16">
      <a
        href={site.support.buyMeACoffee}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-5 py-3 font-semibold text-base rounded-lg
               bg-yellow-300 text-black hover:bg-yellow-400
               focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500
               transition-colors duration-200"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          class="w-5 h-5 flex-shrink-0"
          aria-hidden="true"
        >
          <path
            d="M2 8h2V5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v3h2a1 1 0 0 1 1 1v2a4 4 0 0 1-4 4h-.5A5.001 5.001 0 0 1 14 18.9V20h1a1 1 0 0 1 0 2H9a1 1 0 0 1 0-2h1v-1.1A5.001 5.001 0 0 1 5.5 15H5a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1zm16 5a2 2 0 0 0 2-2v-1h-2v3zM4 11v-1H2v1a2 2 0 0 0 2 2V11z"
          >
          </path>
        </svg>
        Buy me a coffee
      </a>

      <a
        href={site.support.paypal}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-5 py-3 font-semibold text-base rounded-lg
               bg-white text-blue-700 border border-blue-300 hover:bg-blue-50
               focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500
               transition-colors duration-200"
      >
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" aria-hidden="true">
          <path
            d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106zm14.146-14.42a3.35 3.35 0 0 0-.607-.541c-.013.076-.026.175-.041.254-.93 4.778-4.005 7.201-9.138 7.201h-2.19a.563.563 0 0 0-.556.479l-1.187 7.527h-.506l-.24 1.516a.56.56 0 0 0 .554.647h3.882c.46 0 .85-.334.922-.788.06-.26.76-4.852.816-5.09a.932.932 0 0 1 .923-.788h.58c3.76 0 6.705-1.528 7.565-5.946.36-1.847.174-3.388-.777-4.471z"
            fill="#009cde"
          >
          </path>
        </svg>
        Donate with PayPal
      </a>

      <a
        href={site.support.githubSponsor}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-3 px-5 py-3 font-semibold text-base rounded-lg
               bg-neutral-900 text-white hover:bg-neutral-700
               focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-neutral-500
               transition-colors duration-200"
      >
        <svg class="h-5 w-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"
          >
          </path>
        </svg>
        Sponsor on GitHub
      </a>
    </div>

    <div class="border-t border-neutral-200 pt-10">
      <h2 class="text-xl font-bold text-neutral-800 mb-6">Donate with Bitcoin</h2>
      <Image
        src={BitcoinQR}
        class="rounded-lg border border-neutral-200"
        alt="Bitcoin QR code for donations"
        loading="lazy"
      />
    </div>
  </div>
</DefaultLayout>
