---
import DefaultLayout from '../layouts/Default.astro';
import ContactForm from '~/components/ContactForm.astro';
---

<DefaultLayout>
  <div class="max-w-lg mx-auto w-full py-10">
    <h1 class="text-2xl font-bold text-neutral-900 mb-3">Contact</h1>
    <p class="text-base text-neutral-600 leading-relaxed mb-8">
      Have a question, project idea, or just want to say hi? Fill out the form below and I'll get back to you.
    </p>
    <ContactForm />
  </div>
</DefaultLayout>
