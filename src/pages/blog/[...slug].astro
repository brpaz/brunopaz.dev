---
import { getCollection, render } from 'astro:content';
import type { BlogPost } from '~/content/types';
import type { CollectionEntry } from 'astro:content';
import { BlogPostCollection } from '~/content/types';
import DefaultLayout from '~/layouts/Default.astro';
import FormattedDate from '~/components/blog/FormattedDate.astro';
import TagsList from '~/components/blog/TagsList.astro';
import GiscusComments from '~/components/blog/GiscusComments.astro';
interface Props {
  post: CollectionEntry<BlogPost>;
}

export async function getStaticPaths() {
  const posts = await getCollection(BlogPostCollection);
  return posts.map((post) => ({
    params: { slug: post.data.permalink },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, publishDate, excerpt } = post.data;
const ogImage = `/open-graph/${post.data.permalink}.png`;
const { Content } = await render(post);

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: excerpt,
  url: new URL(`/blog/${post.data.permalink}`, Astro.site).toString(),
  datePublished: publishDate?.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Bruno Paz',
    url: 'https://brunopaz.dev',
  },
  image: new URL(ogImage, Astro.site).toString(),
  keywords: post.data.tags.join(', '),
};
---

<style is:global>
  .post-content img {
    display: flex;
    margin: 0 auto;
    border-radius: 0.5rem;
    box-shadow:
      0 4px 6px -1px rgb(0 0 0 / 0.1),
      0 2px 4px -2px rgb(0 0 0 / 0.1);
  }
</style>

<DefaultLayout title=`${title} — Bruno Paz` description={excerpt} ogImage={ogImage} jsonLd={blogPostSchema}>
  <div class="max-w-4xl mx-auto">
    <article class="h-entry mb-16">
      <a class="u-url" href={Astro.url.href} hidden></a>
      <a class="p-author h-card" href="https://brunopaz.dev" rel="author" hidden>Bruno Paz</a>
      <header class="mb-12 text-center pb-12 border-b border-neutral-200">
        <a
          href="/blog/page/1"
          class="inline-flex items-center gap-1 text-sm text-neutral-500 hover:text-primary-500 transition-colors duration-200 mb-8"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Blog
        </a>
        <h1 class="p-name font-bold text-4xl text-center text-neutral-700 mb-component">{title}</h1>
        <div class="flex items-baseline justify-center gap-3 mt-6">
          {
            publishDate && (
              <span class="text-xs text-neutral-400">
                <FormattedDate date={publishDate} />
              </span>
            )
          }
          {post.data.tags.length > 0 && <TagsList tags={post.data.tags} />}
        </div>
      </header>

      <div class="e-content post-content prose prose-lg prose-neutral max-w-none">
        <Content />
      </div>
    </article>

    <GiscusComments />
  </div>
</DefaultLayout>
